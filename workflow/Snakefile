# `blast_pkl2parquet` is a Snakemake checkpoint (B1). Its parquet output is
# the source-of-truth for which species produced tBLASTn hits. Downstream
# aggregate rules read the parquet at runtime via species_with_hits(wildcards)
# to resolve which per-genome files they should demand. See the docstring on
# species_with_hits() at the top of this file for the mechanism.
checkpoint blast_pkl2parquet:
    input:
        pkl_species=expand(os.path.join(defaults.PATH_DICT['TBLASTN_PICKLE_DIR'],'{genome}.pkl'), genome=SPECIES)
    output:
        csv_full=os.path.join(defaults.PATH_DICT['FULL_GENOME_BLAST_CSV_DIR'], 'full_genome_blast.csv'),
        parquet_full=os.path.join(defaults.PATH_DICT['FULL_GENOME_BLAST_PARQUET_DIR'], 'full_genome_blast.parquet')
    params:
        tmp_dir=defaults.PATH_DICT['TMP_DIR']
    threads: config.get('rule_threads', 1)
    shell:
        '''
        rm -rf {params.tmp_dir:q} && \
        python scripts/obj2dict.py --files {input.pkl_species:q} \
            --csv_path {output.csv_full:q} --parquet_path {output.parquet_full:q}
        '''

rule species_segmenter_setup:
    input:
        input_parquet = rules.blast_pkl2parquet.output.parquet_full
    output:
        # Aggregate outputs (all main / all accessory) — always present.
        all_parquet=expand(os.path.join(defaults.PATH_DICT['SEGMENTED_SPECIES_PARQUET_DIR'], 'all{suffix}.parquet'),
                           suffix=['_main', '_accessory']),
        all_csv=expand(os.path.join(defaults.PATH_DICT['SEGMENTED_SPECIES_CSV_DIR'], 'all{suffix}.csv'),
                       suffix=['_main', '_accessory']),
        # Per-species outputs: declared over the FULL SPECIES list (not
        # SPECIES_POST-equivalent) so Snakemake can resolve per-{genome}
        # dependencies from downstream rules. species_segmenter.R ensures
        # every SPECIES gets a table written — empty-schema for species
        # with no hits. Downstream aggregates demand only the hit subset
        # via species_with_hits(wildcards) lambdas.
        species_parquet_full=expand(os.path.join(defaults.PATH_DICT['SEGMENTED_SPECIES_PARQUET_DIR'], '{genome}.parquet'),
                                    genome=SPECIES),
        species_csv_full=expand(os.path.join(defaults.PATH_DICT['SEGMENTED_SPECIES_CSV_DIR'], '{genome}.csv'),
                                genome=SPECIES)
    threads: config.get('rule_threads',1)
    params:
        parquet_dir = defaults.PATH_DICT['SEGMENTED_SPECIES_PARQUET_DIR'],
        csv_dir = defaults.PATH_DICT['SEGMENTED_SPECIES_CSV_DIR'],
        config_file = defaults.CONFIG_FILE,
        species_list = ",".join(SPECIES)
    shell:
        'Rscript scripts/species_segmenter.R \
        --input_file {input.input_parquet:q} \
        --parquet_dir {params.parquet_dir:q} \
        --csv_dir {params.csv_dir:q} \
        --config_file {params.config_file:q} \
        --species {params.species_list:q}'

rule species_segmenter:
    input:
        rules.species_segmenter_setup.output


rule ranges_analysis_setup:
    input:
        # Per-genome scoping (A4): each invocation of this rule needs only
        # one species's fasta, segmented parquet, and ltrdigest GFF3 — the R
        # script reads exactly those three per run. The pre-refactor
        # expand(...) across SPECIES_POST blocked per-species parallelism
        # and demanded every species' files before ANY genome's ranges-analysis
        # could run.
        original_fasta    = os.path.join(defaults.PATH_DICT['SPECIES_DB'],           '{genome}.fa'),
        species_segmented = os.path.join(defaults.PATH_DICT['SEGMENTED_SPECIES_PARQUET_DIR'],'{genome}.parquet'),
        ltr_gff3          = os.path.join(defaults.PATH_DICT['LTRDIGEST_DIR'],        '{genome}.gff3'),
        probe_dict        = os.path.join(defaults.PATH_DICT['PROBE_DICT_PARQUET_DIR'], 'probe_dict.parquet')
    output:
        original_tracks=os.path.join(defaults.PATH_DICT['TRACK_ORIGINAL_DIR'], '{genome}.gff3'),
        candidate_tracks=os.path.join(defaults.PATH_DICT['TRACK_CANDIDATES_DIR'], '{genome}.gff3'),
        valid_tracks=os.path.join(defaults.PATH_DICT['TRACK_VALID_DIR'], '{genome}.gff3'),
        valid_tracks_reduced=os.path.join(defaults.PATH_DICT['TRACK_VALID_DIR'],'{genome}_reduced.gff3'),
        # ERV-like composite candidates (parent + child members) + child-locus BED.
        erv_like_tracks=os.path.join(defaults.PATH_DICT['TRACK_ERV_LIKE_DIR'], '{genome}.gff3'),
        erv_like_tracks_bed=os.path.join(defaults.PATH_DICT['TRACK_ERV_LIKE_DIR'], '{genome}.bed'),
        # solo_ltr production has moved to the LTR_retriever-based workstream
        # (separate rule); the file is no longer produced by ranges_analysis.R.
        flanking_ltr=os.path.join(defaults.PATH_DICT['FLANKING_LTR_DIR'],'{genome}.gff3'),
        overlap_matrix_parquet=os.path.join(defaults.PATH_DICT['OVERLAP_MATRIX_PARQUET_DIR'],'{genome}.parquet'),
        overlap_matrix_csv=os.path.join(defaults.PATH_DICT['OVERLAP_MATRIX_CSV_DIR'],'{genome}.csv'),
        # Per-genome ranges-analysis tables — parquet (pipeline-internal, under
        # data/tables/) + CSV (user-facing, under results/tables/) for each.
        final_loci_parquet=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.final_loci.parquet'),
        final_loci_csv=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_CSV_DIR'],'{genome}.final_loci.csv'),
        homology_loci_parquet=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.homology_loci.parquet'),
        homology_loci_csv=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_CSV_DIR'],'{genome}.homology_loci.csv'),
        ltr_structure_parquet=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.ltr_structure.parquet'),
        ltr_structure_csv=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_CSV_DIR'],'{genome}.ltr_structure.csv'),
        reduction_multiplicity_parquet=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.reduction_multiplicity.parquet'),
        reduction_multiplicity_csv=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_CSV_DIR'],'{genome}.reduction_multiplicity.csv'),
        counts_parquet=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.counts.parquet'),
        counts_csv=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_CSV_DIR'],'{genome}.counts.csv'),
        erv_like_loci_parquet=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.erv_like_loci.parquet'),
        erv_like_loci_csv=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_CSV_DIR'],'{genome}.erv_like_loci.csv'),
        erv_like_members_parquet=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.erv_like_members.parquet'),
        erv_like_members_csv=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_CSV_DIR'],'{genome}.erv_like_members.csv'),
        provirus_overlap_parquet=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.provirus_overlap.parquet'),
        provirus_overlap_csv=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_CSV_DIR'],'{genome}.provirus_overlap.csv'),
        ltr_interaction_parquet=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.ltr_interaction.parquet'),
        ltr_interaction_csv=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_CSV_DIR'],'{genome}.ltr_interaction.csv'),
        probe_domain_overlap_parquet=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.probe_domain_overlap.parquet'),
        probe_domain_overlap_csv=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_CSV_DIR'],'{genome}.probe_domain_overlap.csv'),
        reduction_coverage_parquet=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.reduction_coverage.parquet'),
        reduction_coverage_csv=os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_CSV_DIR'],'{genome}.reduction_coverage.csv'),
        manifest=os.path.join(defaults.PATH_DICT['MANIFEST_DIR'],'{genome}.yaml'),
        valid_ranges_reduced_bed=os.path.join(defaults.PATH_DICT['TRACK_VALID_DIR'],'{genome}_reduced.bed')
    params:
        species_db=defaults.PATH_DICT['SPECIES_DB'],
        segmented_species_dir=defaults.PATH_DICT['SEGMENTED_SPECIES_PARQUET_DIR'],
        probes_csv=defaults.PROBE_CSV,
        workflow_dir=defaults.PATH_DICT['WORKFLOW_DIR'],
        ranges_analysis_parquet_dir=defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],
        ranges_analysis_csv_dir=defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_CSV_DIR'],
        ltr_digest_dir=defaults.PATH_DICT['LTRDIGEST_DIR'],
        yaml_config_file=defaults.CONFIG_FILE,
        original_tracks_dir=defaults.PATH_DICT['TRACK_ORIGINAL_DIR'],
        candidate_tracks_dir=defaults.PATH_DICT['TRACK_CANDIDATES_DIR'],
        valid_tracks_dir=defaults.PATH_DICT['TRACK_VALID_DIR'],
        erv_like_tracks_dir=defaults.PATH_DICT['TRACK_ERV_LIKE_DIR'],
        flanking_ltr_dir=defaults.PATH_DICT['FLANKING_LTR_DIR'],
        manifest_dir=defaults.PATH_DICT['MANIFEST_DIR'],
    threads:
        workflow.cores   # Apparently doesn't take well to multicore
    shell:
        '''
        Rscript scripts/ranges_analysis.R \
        --fasta {params.species_db:q}/{wildcards.genome:q}.fa \
        --blast {params.segmented_species_dir:q}/{wildcards.genome:q}.parquet \
        --ltrdigest {params.ltr_digest_dir:q}/{wildcards.genome:q}.gff3 \
        --probes {params.probes_csv:q} \
        --probe_dict {input.probe_dict:q} \
        --config {params.yaml_config_file:q} \
        --original_ranges {params.original_tracks_dir:q}/{wildcards.genome:q}.gff3 \
        --candidate_ranges {params.candidate_tracks_dir:q}/{wildcards.genome:q}.gff3 \
        --valid_ranges {params.valid_tracks_dir:q}/{wildcards.genome:q}.gff3 \
        --valid_ranges_reduced {params.valid_tracks_dir:q}/{wildcards.genome:q}_reduced.gff3 \
        --erv_like_ranges {params.erv_like_tracks_dir:q}/{wildcards.genome:q}.gff3 \
        --flanking_ltr_ranges {params.flanking_ltr_dir:q}/{wildcards.genome:q}.gff3 \
        --overlap_matrix_parquet {output.overlap_matrix_parquet:q} \
        --overlap_matrix_csv {output.overlap_matrix_csv:q} \
        --ranges_analysis_parquet_dir {params.ranges_analysis_parquet_dir:q} \
        --ranges_analysis_csv_dir {params.ranges_analysis_csv_dir:q} \
        --genome {wildcards.genome:q} \
        --manifest {params.manifest_dir:q}/{wildcards.genome:q}.yaml
        '''


rule ranges_analysis:
    input:
        original_tracks=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['TRACK_ORIGINAL_DIR'], '{genome}.gff3'),
                               genome=species_with_hits(wildcards)),
        candidate_tracks=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['TRACK_CANDIDATES_DIR'],'{genome}.gff3'),
                                genome=species_with_hits(wildcards)),
        valid_tracks=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['TRACK_VALID_DIR'],'{genome}.gff3'),
                             genome=species_with_hits(wildcards)),
        valid_tracks_reduced=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['TRACK_VALID_DIR'],'{genome}_reduced.gff3'),
                                genome=species_with_hits(wildcards)),
        erv_like_tracks=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['TRACK_ERV_LIKE_DIR'],'{genome}.gff3'),
                                genome=species_with_hits(wildcards)),
        erv_like_loci=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.erv_like_loci.parquet'),
                                genome=species_with_hits(wildcards)),
        # solo_ltr aggregation is owned by the LTR_retriever workstream; do not
        # demand solo_ltr/{genome}.gff3 here.
        flanking_ltr=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['FLANKING_LTR_DIR'],'{genome}.gff3'),
                            genome=species_with_hits(wildcards)),
        overlap_matrix=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['OVERLAP_MATRIX_PARQUET_DIR'],'{genome}.parquet'),
                              genome=species_with_hits(wildcards)),
        final_loci=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.final_loci.parquet'),
                               genome=species_with_hits(wildcards)),
        homology_loci=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.homology_loci.parquet'),
                               genome=species_with_hits(wildcards)),
        ltr_structure=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.ltr_structure.parquet'),
                               genome=species_with_hits(wildcards)),
        reduction_multiplicity=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.reduction_multiplicity.parquet'),
                               genome=species_with_hits(wildcards)),
        counts=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],'{genome}.counts.parquet'),
                               genome=species_with_hits(wildcards)),
        manifests=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['MANIFEST_DIR'],'{genome}.yaml'),
                               genome=species_with_hits(wildcards))


# ───────────────────────────── LTR_retriever chain ───────────────────────────
# Pre-filter LTRharvest SCN by RetroSeek's retroviral-confirmed ERV set
# (valid_ranges.gff3) — Coupling A. Then hand the filtered SCN to
# LTR_retriever to discover solo LTRs via BLAST-back of the consensus library
# derived from the retained intact ERVs. See docs/solo_ltr.md for full
# mechanism and the LTR_retriever stages.
rule ltr_retriever_prefilter_setup:
    input:
        scn          = os.path.join(defaults.PATH_DICT['LTR_SCN_DIR'],     '{genome}.scn'),
        des          = os.path.join(defaults.PATH_DICT['SPECIES_DB'],      '{genome}', '{genome}.des'),
        valid_ranges = os.path.join(defaults.PATH_DICT['TRACK_VALID_DIR'], '{genome}.gff3')
    output:
        retroviral_scn = os.path.join(defaults.PATH_DICT['LTR_SCN_DIR'], '{genome}_retroviral.scn'),
        full_scn       = os.path.join(defaults.PATH_DICT['LTR_SCN_DIR'], '{genome}_full.scn')
    log:
        os.path.join(defaults.PATH_DICT['LOG_DIR'], 'ltr_retriever_prefilter', '{genome}.log')
    threads: 1
    shell:
        '''
        python scripts/ltr_retriever_prefilter.py \
            --scn {input.scn:q} \
            --des {input.des:q} \
            --valid-ranges {input.valid_ranges:q} \
            --output-retroviral {output.retroviral_scn:q} \
            --output-full {output.full_scn:q} \
            2> {log:q}
        '''


rule ltr_retriever_prefilter:
    input:
        retroviral_scn = lambda wildcards: expand(
            os.path.join(defaults.PATH_DICT['LTR_SCN_DIR'], '{genome}_retroviral.scn'),
            genome=species_with_hits(wildcards)
        ),
        full_scn = lambda wildcards: expand(
            os.path.join(defaults.PATH_DICT['LTR_SCN_DIR'], '{genome}_full.scn'),
            genome=species_with_hits(wildcards)
        )


# Invoke LTR_retriever itself. It writes multiple output files into its working
# directory; we declare the three we consume downstream (.pass.list.gff3,
# .nmtf.pass.list, .LTRlib.fa). Other LTR_retriever outputs appear alongside
# them and are considered working files.
rule ltr_retriever_setup:
    input:
        genome_fa      = os.path.join(defaults.PATH_DICT['SPECIES_DB'],     '{genome}.fa'),
        retroviral_scn = os.path.join(defaults.PATH_DICT['LTR_SCN_DIR'],    '{genome}_retroviral.scn'),
        full_scn       = os.path.join(defaults.PATH_DICT['LTR_SCN_DIR'],    '{genome}_full.scn')
    output:
        pass_list_gff3 = os.path.join(defaults.PATH_DICT['LTR_RETRIEVER_DIR'], '{genome}', '{genome}.pass.list.gff3'),
        nmtf_pass_list = os.path.join(defaults.PATH_DICT['LTR_RETRIEVER_DIR'], '{genome}', '{genome}.nmtf.pass.list'),
        ltr_library    = os.path.join(defaults.PATH_DICT['LTR_RETRIEVER_DIR'], '{genome}', '{genome}.LTRlib.fa')
    log:
        os.path.join(defaults.PATH_DICT['LOG_DIR'], 'ltr_retriever', '{genome}.log')
    params:
        out_dir           = os.path.join(defaults.PATH_DICT['LTR_RETRIEVER_DIR'], '{genome}'),
        source_scn_mode   = config['ltr_retriever'].get('source_scn', 'retroviral'),
        substitution_rate = config['ltr_retriever'].get('substitution_rate', 1.3e-8),
        min_similarity    = config['ltr_retriever'].get('min_ltr_similarity', 91),
        noanno_flag       = '--noanno' if config['ltr_retriever'].get('noanno', True) else ''
    threads: lambda wildcards: config['ltr_retriever'].get('threads_per_genome', 4)
    shell:
        '''
        python scripts/run_ltr_retriever.py \
            --genome-fa {input.genome_fa:q} \
            --retroviral-scn {input.retroviral_scn:q} \
            --full-scn {input.full_scn:q} \
            --source-scn-mode {params.source_scn_mode} \
            --workdir {params.out_dir:q} \
            --genome-name {wildcards.genome:q} \
            --substitution-rate {params.substitution_rate} \
            --min-similarity {params.min_similarity} \
            --threads {threads} \
            {params.noanno_flag} \
            --log-file {log:q}
        '''


rule ltr_retriever:
    input:
        pass_gff3 = lambda wildcards: expand(
            os.path.join(defaults.PATH_DICT['LTR_RETRIEVER_DIR'], '{genome}', '{genome}.pass.list.gff3'),
            genome=species_with_hits(wildcards)
        ),
        nmtf      = lambda wildcards: expand(
            os.path.join(defaults.PATH_DICT['LTR_RETRIEVER_DIR'], '{genome}', '{genome}.nmtf.pass.list'),
            genome=species_with_hits(wildcards)
        ),
        lib       = lambda wildcards: expand(
            os.path.join(defaults.PATH_DICT['LTR_RETRIEVER_DIR'], '{genome}', '{genome}.LTRlib.fa'),
            genome=species_with_hits(wildcards)
        )


# Integrate LTR_retriever output with RetroSeek's valid_ranges (Coupling B).
# Emits the final annotated solo-LTR GFF3 + per-genome solo/intact ratio CSV.
rule solo_ltr_integrator_setup:
    input:
        nmtf         = os.path.join(defaults.PATH_DICT['LTR_RETRIEVER_DIR'], '{genome}', '{genome}.nmtf.pass.list'),
        ltr_library  = os.path.join(defaults.PATH_DICT['LTR_RETRIEVER_DIR'], '{genome}', '{genome}.LTRlib.fa'),
        valid_ranges = os.path.join(defaults.PATH_DICT['TRACK_VALID_DIR'],   '{genome}.gff3')
    output:
        solo_ltr_gff3 = os.path.join(defaults.PATH_DICT['SOLO_LTR_DIR'],            '{genome}.gff3'),
        ratio_csv     = os.path.join(defaults.PATH_DICT['SOLO_INTACT_CSV_DIR'],     '{genome}.csv'),
        ratio_parquet = os.path.join(defaults.PATH_DICT['SOLO_INTACT_PARQUET_DIR'], '{genome}.parquet')
    params:
        nearest_distance = config['ltr_retriever'].get('nearest_erv_max_distance', 10000)
    threads: 1
    shell:
        '''
        python scripts/solo_ltr_integrator.py \
            --nmtf-pass-list {input.nmtf:q} \
            --ltr-library {input.ltr_library:q} \
            --valid-ranges {input.valid_ranges:q} \
            --genome {wildcards.genome:q} \
            --output-gff3 {output.solo_ltr_gff3:q} \
            --output-ratio-csv {output.ratio_csv:q} \
            --output-ratio-parquet {output.ratio_parquet:q} \
            --nearest-erv-max-distance {params.nearest_distance}
        '''


# Aggregate per-genome ratio CSVs into all_species.csv via an inline pandas
# concat. Tiny helper — not worth its own script.
rule solo_intact_ratio_aggregate:
    input:
        per_genome = lambda wildcards: expand(
            os.path.join(defaults.PATH_DICT['SOLO_INTACT_PARQUET_DIR'], '{genome}.parquet'),
            genome=species_with_hits(wildcards)
        )
    output:
        all_species_csv = os.path.join(defaults.PATH_DICT['SOLO_INTACT_CSV_DIR'], 'all_species.csv'),
        all_species_parquet = os.path.join(defaults.PATH_DICT['SOLO_INTACT_PARQUET_DIR'], 'all_species.parquet')
    threads: 1
    run:
        import pandas as pd
        frames = [pd.read_parquet(p) for p in input.per_genome]
        if frames:
            combined = pd.concat(frames, ignore_index=True)
        else:
            combined = pd.DataFrame(
                columns=['species', 'probe_family', 'label_mode',
                         'intact_count', 'solo_count', 'total_integrations',
                         'solo_to_intact_ratio', 'solo_fraction']
            )
        combined.to_csv(output.all_species_csv, index=False)
        combined.to_parquet(output.all_species_parquet, index=False)


# Top-level aggregate — the CLI target. Demands every per-genome GFF3 + the
# aggregate CSV, triggering the whole LTR_retriever chain transitively.
rule solo_ltr_detector:
    input:
        solo_gff3 = lambda wildcards: expand(
            os.path.join(defaults.PATH_DICT['SOLO_LTR_DIR'], '{genome}.gff3'),
            genome=species_with_hits(wildcards)
        ),
        all_species = rules.solo_intact_ratio_aggregate.output.all_species_csv


