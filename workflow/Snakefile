        plot_dir=defaults.PATH_DICT['PROVIRUS_PLOT_DIR'],
        config_yaml=defaults.CONFIG_FILE
    threads:
        workflow.cores
    shell:
        '''
        Rscript scripts/stage_plot_generator.R \
        --input {params.ranges_analysis_parquet_dir:q} \
        --output {params.plot_dir:q} \
        --config {params.config_yaml:q}
        '''


