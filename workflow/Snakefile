                               genome=species_with_hits(wildcards))
    output:
        density_plots=expand(os.path.join(defaults.PATH_DICT['PROVIRUS_PLOT_DIR'],'{density_probe}_density.png'),
                             density_probe=['main','accessory']),
        raincloud_plots=expand(os.path.join(defaults.PATH_DICT['PROVIRUS_PLOT_DIR'],'{raincloud_probe}_raincloud.png'),
                               raincloud_probe=['main','accessory']),
        bar_plots=expand(os.path.join(defaults.PATH_DICT['PROVIRUS_PLOT_DIR'],'{bar_probe}_bar.png'),
                         bar_probe=['full', 'main','accessory']),
        sankey_plots=expand(os.path.join(defaults.PATH_DICT['PROVIRUS_PLOT_DIR'],'{sankey_probe}_sankey_{plot_type}.png'),
                            sankey_probe=['main','accessory'], plot_type=['a', 'b', 'c']),
        balloon_plots=expand(os.path.join(defaults.PATH_DICT['PROVIRUS_PLOT_DIR'],'{balloon_probe}_balloon.png'),
                             balloon_probe=['main','accessory']),
        query_coverage_plots=expand(os.path.join(defaults.PATH_DICT['PROVIRUS_PLOT_DIR'],'{qc_probe}_query_coverage.png'),
                                    qc_probe=['main','accessory']),
        heatmap_plots=expand(os.path.join(defaults.PATH_DICT['PROVIRUS_PLOT_DIR'],'{hm_probe}_heatmap_probe_species.png'),
                             hm_probe=['main','accessory']),
        waffle_plots=expand(os.path.join(defaults.PATH_DICT['PROVIRUS_PLOT_DIR'],'{wf_probe}_waffle_virus.png'),
                            wf_probe=['main','accessory'])
    params:
        ranges_analysis_parquet_dir=defaults.PATH_DICT['RANGES_ANALYSIS_TABLES_PARQUET_DIR'],
        plot_dir=defaults.PATH_DICT['PROVIRUS_PLOT_DIR'],
        config_yaml = defaults.CONFIG_FILE
    threads:
        workflow.cores
    shell:
        '''
        Rscript scripts/plot2sort.R \
        --input {params.ranges_analysis_parquet_dir:q} \
        --output {params.plot_dir:q} \
        --config {params.config_yaml:q}
        '''


rule plot_generator:
    input:
        plots=rules.plot_generator_setup.output


