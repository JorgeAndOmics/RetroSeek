# TODO: SUFFIX PARSING
rule hotspot_detector_setup:
    input:
        # Per-genome scoping (A5): previously this rule demanded
        # rules.ranges_analysis.input — which expands across ALL species, so
        # producing one genome's hotspots required every species's tracks.
        # The hotspot_detector.R shell command below actually reads only
        # {params.input_track_dir}/{wildcards.genome}.gff3 + {wildcards.genome}.fa.
        # Declare those as inputs directly so Snakemake schedules the rule
        # per-{genome} and per-species parallelism works.
        fasta = os.path.join(defaults.PATH_DICT['SPECIES_DB'], '{genome}.fa'),
        track = os.path.join(defaults.PATH_DICT['TRACK_ORIGINAL_DIR'], '{genome}.gff3')
    output:
        hotspot_csv=os.path.join(defaults.PATH_DICT['HOTSPOT_CSV_DIR'], '{genome}.csv'),
        hotspot_parquet=os.path.join(defaults.PATH_DICT['HOTSPOT_PARQUET_DIR'], '{genome}.parquet'),
        hotspot_histogram_pdf=os.path.join(defaults.PATH_DICT['HOTSPOT_PDF_DIR'], '{genome}_histogram.pdf'),
        hotspot_density_pdf=os.path.join(defaults.PATH_DICT['HOTSPOT_PDF_DIR'], '{genome}_density.pdf'),
        hotspot_heatmap_pdf=os.path.join(defaults.PATH_DICT['HOTSPOT_PDF_DIR'], '{genome}_heatmap.pdf'),
        hotspot_track=os.path.join(defaults.PATH_DICT['TRACK_HOTSPOTS_DIR'], '{genome}.gff3')
    params:
        genomes_dir=defaults.PATH_DICT['SPECIES_DB'],
        input_track_dir=defaults.PATH_DICT['TRACK_ORIGINAL_DIR'],          # For now
        window_size=config['parameters'].get('hotspot_window_size', 10000),
        mask_size=config['parameters'].get('hotspot_mask_size', 20),
        mask_mismatch=config['parameters'].get('hotspot_mask_mismatch', 2),
        permutations=config['parameters'].get('hotspot_permutations', 3),
        pvalue_threshold=config['parameters'].get('hotspot_pvalue_threshold', 0.05),
        csv_dir=defaults.PATH_DICT['HOTSPOT_CSV_DIR'],
        parquet_dir=defaults.PATH_DICT['HOTSPOT_PARQUET_DIR'],
        pdf_dir=defaults.PATH_DICT['HOTSPOT_PDF_DIR'],
        track_dir=defaults.PATH_DICT['TRACK_HOTSPOTS_DIR'],
        config_yaml = defaults.CONFIG_FILE
    threads:
        workflow.cores
    shell:
        '''
        Rscript scripts/hotspot_detector.R \
        --fasta {params.genomes_dir:q}/{wildcards.genome}.fa \
        --gff {params.input_track_dir:q}/{wildcards.genome}.gff3 \
        --config {params.config_yaml:q} \
        --parquet_dir {params.parquet_dir:q} \
        --csv_dir {params.csv_dir:q} \
        --pdf_output_dir {params.pdf_dir:q} \
        --hotspot_output_dir {params.track_dir:q}
        '''

rule hotspot_detector:
    input:
        hotspot_csv=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['HOTSPOT_CSV_DIR'], '{genome}.csv'), genome=species_with_hits(wildcards)),
        hotspot_histogram_pdf=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['HOTSPOT_PDF_DIR'], '{genome}_histogram.pdf'), genome=species_with_hits(wildcards)),
        hotspot_density_pdf=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['HOTSPOT_PDF_DIR'], '{genome}_density.pdf'), genome=species_with_hits(wildcards)),
        hotspot_heatmap_pdf=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['HOTSPOT_PDF_DIR'], '{genome}_heatmap.pdf'), genome=species_with_hits(wildcards)),
        hotspot_track=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['TRACK_HOTSPOTS_DIR'], '{genome}.gff3'), genome=species_with_hits(wildcards))


rule pair_detector_setup:
    input:
        gff3_file=os.path.join(defaults.PATH_DICT['TRACK_VALID_DIR'], '{genome}.gff3'),
    output:
        pair_table_csv=os.path.join(defaults.PATH_DICT['PROBE_PAIRS_CSV_DIR'], '{genome}.csv'),
        pair_table_parquet=os.path.join(defaults.PATH_DICT['PROBE_PAIRS_PARQUET_DIR'], '{genome}.parquet')
    params:
        config_yaml=defaults.CONFIG_FILE,
        parquet_dir=defaults.PATH_DICT['PROBE_PAIRS_PARQUET_DIR'],
        csv_dir=defaults.PATH_DICT['PROBE_PAIRS_CSV_DIR']
    threads:
        workflow.cores
    shell:
        '''
        Rscript scripts/pair_detector.R \
        --config {params.config_yaml:q} \
        --gff {input.gff3_file:q} \
        --parquet_dir {params.parquet_dir:q} \
        --csv_dir {params.csv_dir:q}
        '''

rule pair_detector:
    input:
        pair_table_csv=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['PROBE_PAIRS_CSV_DIR'], '{genome}.csv'), genome=species_with_hits(wildcards)),
        pair_table_parquet=lambda wildcards: expand(os.path.join(defaults.PATH_DICT['PROBE_PAIRS_PARQUET_DIR'], '{genome}.parquet'), genome=species_with_hits(wildcards))