# ──────────────────────────────────────────────
# IDE / editor
# ──────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.swp
*~

# ──────────────────────────────────────────────
# Claude Code workspace (repo-local, never committed)
# CLAUDE.md and everything under .claude/ are Claude-exclusive.
# Only human-facing artifacts (docs/, README.md) are committed.
# ──────────────────────────────────────────────
/CLAUDE.md
.claude/

# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
*.egg-info/
build/
dist/

# ──────────────────────────────────────────────
# R
# ──────────────────────────────────────────────
.RData
.Rhistory
.Rapp.history
.Ruserdata
.Rproj.user/

# ──────────────────────────────────────────────
# Snakemake
# ──────────────────────────────────────────────
.snakemake/
workflow/.snakemake/
logs/
/logs/*

# ──────────────────────────────────────────────
# Pipeline outputs (user runs locally; not versioned)
# ──────────────────────────────────────────────
results/
data/pickles/
data/species/
data/tables/
data/tmp/*
!data/tmp/

# ──────────────────────────────────────────────
# Local config overrides (per-machine; see data/config/config.example.yaml)
# ──────────────────────────────────────────────
data/config/config.local.yaml

# ──────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────
*.pptx
*.DS_Store
Thumbs.db
